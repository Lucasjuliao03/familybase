PORT=3001
NEXT_PUBLIC_SUPABASE_URL=https://<SUA-URL>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUA-SERVICE-ROLE-KEY>

# --- PostgreSQL (FamilyBase API usa este URL com o driver `pg`) ---
# No painel: Project Settings → Database → Connection string → URI
# Substitua [PASSWORD] pela password da base (não a anon key).
#
# Ligação direta (porta 5432):
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# ou formato clássico:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
#
# O [REF] é o "Project reference id" (Settings → General → Reference ID). Tem de coincidir
# com o hostname; se estiver errado verá ENOTFOUND e login/registo devolvem 503.
#
# IPv4 / redes restritas: experimente Session pooler (porta 6543) na mesma página de Database.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
